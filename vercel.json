{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": [
    {
      "key": "VITE_SUPABASE_URL",
      "description": "URL do projeto Supabase"
    },
    {
      "key": "VITE_SUPABASE_ANON_KEY",
      "description": "Chave anônima do Supabase"
    }
  ]
}
